/* Program 3.3: Write a Java program to search for a given element in a one-dimensional array and display its position(s) if found. */
import java.util.Scanner;
public class ArrayOperations {
    public static void main(String[] args) {
        Scanner s = new Scanner (System.in);
        System.out.println("Enter the number of elements\n");
        int size = s.nextInt();
        int [] array = new int [size];
        readElements(array,size,s);
    }
    public static void readElements(int[] arr, int n, Scanner s){
        System.out.println("Enter the elements:\n");
        for(int i=0; i<n; i++){
            arr[i] = s.nextInt();
        }
        System.out.println("Enter the element you wish to find:\n");
        int lost = s.nextInt();
        findElement(arr,n,lost);
    }
    public static void findElement(int[] arr, int n, int lost){
        int i, found = 0;
        for(i=0; i<n; i++){
            if(arr[i]==lost){
                found=1;
                break;
            }
        }
        if(found==1){
                System.out.println("The element "+lost+" was found at "+i);
        }
        else{
            System.out.println("The element is NOT present");
        }
    }
}
